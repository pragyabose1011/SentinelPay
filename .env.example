# ============================================================
# SentinelPay — environment variables
# Copy to .env and fill in real values. Never commit .env.
# ============================================================

# ---- Database -----------------------------------------------
DB_USERNAME=sentinelpay
DB_PASSWORD=change-me-strong-db-password

# ---- JWT (access token, HS256) ------------------------------
# Must be at least 32 characters. Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-me-min-32-chars-access-secret!!

# ---- JWT refresh token secret -------------------------------
# Separate secret for signing refresh tokens. Generate with:
#   openssl rand -base64 48
JWT_REFRESH_SECRET=change-me-min-32-chars-refresh-secret!

# ---- Token expiry -------------------------------------------
JWT_EXPIRATION_MS=900000         # 15 minutes
JWT_REFRESH_EXPIRATION_MS=604800000  # 7 days

# ---- TLS keystore ----------------------------------------
SSL_KEYSTORE_PASSWORD=change-me-keystore-password

# ---- Mail (Mailhog in dev, real SMTP in prod) ---------------
MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM=noreply@sentinelpay.com
# For prod, set host/port to your SMTP provider and add credentials

# ---- Razorpay (payment gateway) ----------------------------
# Set RAZORPAY_ENABLED=true and fill real credentials in prod.
# Dev runs with enabled=false (direct wallet credit, no gateway).
RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ---- Brute-force protection ---------------------------------
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_DURATION_MINUTES=30
AUTH_FAILURE_WINDOW_MINUTES=15
FRONTEND_BASE_URL=http://localhost:3000

# ---- Observability ----------------------------------------
# Grafana admin password (default: sentinelpay in dev)
GRAFANA_PASSWORD=change-me-grafana-password
